#!/usr/bin/env bash
set -u

# dbox - lightweight Docker sandbox manager
#
# Config file format (shell variables):
#   DBOX_CONTAINER=<name>    # container name (optional)
#   DBOX_IMAGE=<image>       # Docker image to use
#   DBOX_DIR=<path>          # host path mounted to /app (optional)
#   DBOX_ENV=(KEY=val ...)   # optional extra environment variables (optional)
#   DBOX_INIT=("cmd1" ...)   # optional commands to run after container creation (optional)
#   DBOX_MOUNT=("host_path:container_path" ...) # optional extra mounts (optional)   

# disable Docker CLI hints for cleaner output
export DOCKER_CLI_HINTS=false

# Use an array for TTY args to handle word splitting safely
TTY_ARGS=("-i")
[[ -t 0 ]] && TTY_ARGS+=("-t")

container_status() {
    local status
    if status="$(docker inspect --format '{{.State.Status}}' "$DBOX_CONTAINER" 2>/dev/null)"; then
        echo "$status"
    else
        echo "absent"
    fi
}

start() {
    local status=$(container_status)
    case "$status" in
        running)
            echo "Container is already running: $DBOX_CONTAINER"
            ;;
        absent)
            echo "Creating and starting container: $DBOX_CONTAINER"
            local env_args=()
            for e in ${DBOX_ENV[@]+"${DBOX_ENV[@]}"}; do
                env_args+=(-e "$e")
            done
            # take MOUNT entries and convert to -v args
            local mount_args=(-v "$DBOX_DIR:$DBOX_DIR")
            for m in ${DBOX_MOUNT[@]+"${DBOX_MOUNT[@]}"}; do
                mount_args+=(-v "$m")
            done
            docker run -d --name "$DBOX_CONTAINER" \
                --net=host  \
                "${mount_args[@]}" \
                ${env_args[@]+"${env_args[@]}"} \
                -w "$DBOX_DIR" "$DBOX_IMAGE" sleep infinity
            for init_cmd in ${DBOX_INIT[@]+"${DBOX_INIT[@]}"}; do
                echo "Running init: $init_cmd"
                exec_cmd sh -c "$init_cmd"
            done
            ;;
        *)
            echo "Starting existing container: $DBOX_CONTAINER"
            docker start "$DBOX_CONTAINER"
            ;;
    esac
}

exec_cmd() {
    [[ $# -eq 0 ]] && { echo "Error: Command required" >&2; exit 1; }
    local env_args=()
    for e in ${DBOX_ENV[@]+"${DBOX_ENV[@]}"}; do
        env_args+=(-e "$e")
    done
    docker exec "${TTY_ARGS[@]}" ${env_args[@]+"${env_args[@]}"} "$DBOX_CONTAINER" "$@"
}

stop() {
    docker stop "$DBOX_CONTAINER" >/dev/null 2>&1 || true
    echo "Stopped: $DBOX_CONTAINER"
}

clean() {
    docker rm -f "$DBOX_CONTAINER" >/dev/null 2>&1 || true
    echo "Removed container: $DBOX_CONTAINER"
}

info() {
    local status=$(container_status)
    echo "Container: $DBOX_CONTAINER"
    echo "Status: $status"
    if [[ "$status" != "absent" ]]; then
        docker inspect "$DBOX_CONTAINER" --format='
Image: {{.Config.Image}}
ID: {{.ID | printf "%.12s"}}
Created: {{.Created}}
Mounts:
{{- range .Mounts}}
  - {{.Source}} -> {{.Destination}}{{end}}
Environment:
{{- range .Config.Env}}
  - {{.}}{{end}}'
    fi
}

usage() {
    cat <<EOF
Usage: dbox [-f <file>] <option> [args]

Arguments:
    file         Config file (sets DBOX_CONTAINER, DBOX_IMAGE, etc.)

Options:
    -f, --file <file> Specify a config file; defaults to .dbox in the current directory
    -s, --start      Create (or restart) the container
    -e, --exec <cmd> Run a command inside the container
    -i, --info       Show container information
    -S, --stop       Stop the container
    -c, --clean      Remove the container
EOF
}

load_config() {
    local config_file="${1:-}"
    if [[ -n "$config_file" ]]; then
        if [[ -f "$config_file" ]]; then
            source "$config_file"
        else
            echo "Error: Config file '$config_file' not found." >&2
            exit 1
        fi
    fi

    # Set default values if not defined (evaluated after sourcing config)
    DBOX_CONTAINER="${DBOX_CONTAINER:-${PWD/#$HOME\//}}"
    DBOX_CONTAINER="${DBOX_CONTAINER//[^a-zA-Z0-9_.-]/-}"
    DBOX_DIR="${DBOX_DIR:-$(pwd)}"
    DBOX_IMAGE="${DBOX_IMAGE:-alpine:latest}"

    # Ensure required configuration variables are set
    for var in DBOX_CONTAINER DBOX_IMAGE DBOX_DIR; do
        if [[ -z "${!var:-}" ]]; then
            echo "Error: $var is not set. Please set it in the environment or a config file." >&2
            exit 1
        fi
        export "$var"
    done
}

config_file=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        help|-h|--help)
            usage
            exit 0
            ;;
        -f|--file)
            shift
            [[ $# -eq 0 ]] && { echo "Error: option '--file' requires a file argument" >&2; usage >&2; exit 1; }
            config_file="$1"
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            break
            ;;
        *)
            if [[ -z "$config_file" && -f "$1" ]]; then
                config_file="$1"
                shift
                continue
            fi
            break
            ;;
    esac
done

config_file="${config_file:-.dbox}"
subcmd="${1:-}"
[[ -z "$subcmd" ]] && { echo "Error: option required" >&2; usage >&2; exit 1; }
shift

load_config "$config_file"

case "$subcmd" in
    -s|--start)  start ;;
    -e|--exec)   exec_cmd "$@" ;;
    -i|--info)   info ;;
    -S|--stop)   stop ;;
    -c|--clean)  stop; clean ;;
    *)
        echo "Unknown option: $subcmd" >&2
        usage >&2
        exit 1
        ;;
esac
